# The engine reads no environment variables in its core path -- this file
# is a placeholder for the optional integrations and the streamlit UI.
#
# Copy to .env to override defaults.

# Optional: Multiflash MCP server URL for rigorous Span-Wagner CO2 EOS.
# When set, src/ccs_costs/thermo/multiflash.py prefers Multiflash over the
# built-in Duan 1992 EOS. Engine falls back silently on any failure.
# MULTIFLASH_MCP_URL=http://localhost:8080

# Optional: Streamlit telemetry / theme overrides
# STREAMLIT_BROWSER_GATHER_USAGE_STATS=false
